import React, { useState, useCallback } from "react";
import { useForm } from "react-hook-form";
import { zodResolver } from "@hookform/resolvers/zod";
import { z } from "zod";
import { motion, AnimatePresence } from "framer-motion";
import { Sparkles, Map, Loader2, Save, Share2, LogIn } from "lucide-react";
import { useLocation } from "wouter";
import { useUser } from "@clerk/react";

import { Button } from "@/components/ui/button";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { SkillAutocomplete } from "@/components/roadmap/skill-autocomplete";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import { useToast } from "@/hooks/use-toast";

import { useGenerateRoadmap, useSaveRoadmap, useShareRoadmap } from "@workspace/api-client-react";
import { RoadmapDisplay } from "@/components/roadmap/roadmap-display";
import { RecentRoadmaps } from "@/components/roadmap/recent-roadmaps";
import { OnboardingFlow } from "@/components/roadmap/onboarding-flow";
import { ExploreSkills } from "@/components/roadmap/explore-skills";
import { AdSenseBanner } from "@/components/roadmap/adsense-banner";
import { useRecentRoadmaps } from "@/hooks/use-recent-roadmaps";
import type { RoadmapResult, RoadmapInputExperienceLevel } from "@workspace/api-client-react/src/generated/api.schemas";

const formSchema = z.object({
  skillName: z.string().min(1, "What do you want to learn?"),
  duration: z.string().min(1, "Please select a duration"),
  experienceLevel: z.enum(["Beginner", "Intermediate", "Advanced"]),
});

type FormValues = z.infer<typeof formSchema>;

export default function Home() {
  const { toast } = useToast();
  const [, setLocation] = useLocation();
  const [result, setResult] = useState<RoadmapResult | null>(null);
  const [savedRoadmapId, setSavedRoadmapId] = useState<number | null>(null);
  const { recent, addRecent, clearRecent } = useRecentRoadmaps();
  const { isSignedIn } = useUser();

  const form = useForm<FormValues>({
    resolver: zodResolver(formSchema),
    defaultValues: {
      skillName: "",
      duration: "1 month",
      experienceLevel: "Beginner",
    },
  });

  const generateRoadmap = useGenerateRoadmap();
  const saveRoadmap = useSaveRoadmap();
  const shareRoadmap = useShareRoadmap();

  const onSubmit = (data: FormValues) => {
    generateRoadmap.mutate(
      { data: {
        skillName: data.skillName,
        duration: data.duration,
        experienceLevel: data.experienceLevel as RoadmapInputExperienceLevel,
      } },
      {
        onSuccess: (res) => {
          setResult(res);
          setSavedRoadmapId(null);
          addRecent(res);
          // Scroll down to result
          setTimeout(() => {
            window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
          }, 100);
        },
        onError: () => {
          toast({
            title: "Generation Failed",
            description: "Failed to generate roadmap. Please try again.",
            variant: "destructive",
          });
        },
      }
    );
  };

  const handleSave = () => {
    if (!result) return;
    saveRoadmap.mutate(
      {
        data: {
          skillName: result.skillName,
          duration: result.duration,
          experienceLevel: result.experienceLevel,
          overview: result.overview,
          roadmapData: JSON.stringify(result),
          totalDays: result.totalDays,
        },
      },
      {
        onSuccess: (res) => {
          setSavedRoadmapId(res.id);
          toast({
            title: "Roadmap Saved",
            description: "Your roadmap has been saved successfully.",
          });
          setLocation("/saved");
        },
        onError: () => {
          toast({
            title: "Save Failed",
            description: "Failed to save the roadmap. Please try again.",
            variant: "destructive",
          });
        },
      }
    );
  };

  const handleShare = async () => {
    if (!result) return;

    let targetId = savedRoadmapId;
    if (!targetId) {
      try {
        const saved = await saveRoadmap.mutateAsync({
          data: {
            skillName: result.skillName,
            duration: result.duration,
            experienceLevel: result.experienceLevel,
            overview: result.overview,
            roadmapData: JSON.stringify(result),
            totalDays: result.totalDays,
          },
        });
        targetId = saved.id;
        setSavedRoadmapId(saved.id);
      } catch (error) {
        toast({
          title: "Share Failed",
          description: "Failed to save roadmap before sharing.",
          variant: "destructive",
        });
        return;
      }
    }

    shareRoadmap.mutate(
      { id: targetId },
      {
        onSuccess: (res) => {
          const shareUrl = window.location.origin + "/share/" + res.shareToken;
          navigator.clipboard.writeText(shareUrl);
          toast({
            title: "Link copied!",
            description: "Share it with anyone.",
          });
        },
        onError: () => {
          toast({
            title: "Share Failed",
            description: "Failed to generate share link. Please try again.",
            variant: "destructive",
          });
        },
      }
    );
  };

  const handleOnboardingComplete = useCallback(
    (values: { skillName: string; experienceLevel: string; duration: string }) => {
      form.setValue("skillName", values.skillName);
      form.setValue("experienceLevel", values.experienceLevel as FormValues["experienceLevel"]);
      form.setValue("duration", values.duration);
      setTimeout(() => {
        form.handleSubmit(onSubmit)();
        window.scrollTo({ top: 400, behavior: "smooth" });
      }, 150);
    },
    [form, onSubmit],
  );

  return (
    <>
      <OnboardingFlow onComplete={handleOnboardingComplete} />
    <div className="container mx-auto px-4 md:px-8 py-12 max-w-7xl">
      <div className="flex flex-col items-center text-center space-y-6 mb-12">
        <div className="inline-flex items-center justify-center p-3 bg-primary/10 text-primary rounded-2xl mb-2">
          <Map className="w-8 h-8" />
        </div>
        <h1 className="text-4xl md:text-6xl font-extrabold tracking-tight text-foreground">
          Master any skill, <br className="hidden md:block" />
          <span className="text-primary">step by step.</span>
        </h1>
        <p className="text-lg md:text-xl text-muted-foreground max-w-2xl">
          Enter what you want to learn, your current level, and how much time you have. 
          We'll generate a personalized, day-by-day learning roadmap tailored just for you.
        </p>
      </div>

      <AdSenseBanner slot="home-top-banner" className="mb-8" />

      <RecentRoadmaps
        recent={recent}
        onSelect={(roadmap) => {
          setResult(roadmap);
          setSavedRoadmapId(null);
          setTimeout(() => {
            window.scrollTo({ top: document.body.scrollHeight, behavior: "smooth" });
          }, 100);
        }}
        onClear={clearRecent}
      />

      <div className={`flex flex-col ${result ? 'lg:flex-row gap-8 items-start justify-center' : 'items-center'} w-full mx-auto`}>
        <div className={`w-full ${result ? 'lg:flex-1' : 'max-w-3xl'} transition-all duration-500`}>
          <div className="bg-card border border-border shadow-xl rounded-3xl p-6 md:p-10 mb-12 relative overflow-hidden">
            {/* Decorative background element */}
            <div className="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-primary/5 rounded-full blur-3xl pointer-events-none" />
            
            <Form {...form}>
              <form onSubmit={form.handleSubmit(onSubmit)} className="space-y-8 relative z-10">
                <div className="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
                  <FormField
                    control={form.control}
                    name="skillName"
                    render={({ field }) => (
                      <FormItem className="md:col-span-2">
                        <FormLabel className="text-base font-semibold">What do you want to learn?</FormLabel>
                        <SkillAutocomplete
                          value={field.value}
                          onChange={field.onChange}
                          data-testid="input-skillName"
                        />
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  <FormField
                    control={form.control}
                    name="duration"
                    render={({ field }) => (
                      <FormItem>
                        <FormLabel className="font-semibold">Duration</FormLabel>
                        <Select onValueChange={field.onChange} defaultValue={field.value}>
                          <FormControl>
                            <SelectTrigger className="h-12 bg-background" data-testid="select-duration">
                              <SelectValue placeholder="Select duration" />
                            </SelectTrigger>
                          </FormControl>
                          <SelectContent>
                            <SelectItem value="1 week">1 week</SelectItem>
                            <SelectItem value="2 weeks">2 weeks</SelectItem>
                            <SelectItem value="1 month">1 month</SelectItem>
                            <SelectItem value="2 months">2 months</SelectItem>
                            <SelectItem value="3 months">3 months</SelectItem>
                          </SelectContent>
                        </Select>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  <FormField
                    control={form.control}
                    name="experienceLevel"
                    render={({ field }) => (
                      <FormItem>
                        <FormLabel className="font-semibold">Current Level</FormLabel>
                        <Select onValueChange={field.onChange} defaultValue={field.value}>
                          <FormControl>
                            <SelectTrigger className="h-12 bg-background" data-testid="select-level">
                              <SelectValue placeholder="Select level" />
                            </SelectTrigger>
                          </FormControl>
                          <SelectContent>
                            <SelectItem value="Beginner">Beginner</SelectItem>
                            <SelectItem value="Intermediate">Intermediate</SelectItem>
                            <SelectItem value="Advanced">Advanced</SelectItem>
                          </SelectContent>
                        </Select>
                        <FormMessage />
                      </FormItem>
                    )}
                  />
                </div>

                <Button 
                  type="submit" 
                  className="w-full h-14 text-lg font-bold gap-2 group" 
                  disabled={generateRoadmap.isPending}
                  data-testid="button-generate"
                >
                  {generateRoadmap.isPending ? (
                    <>
                      <Loader2 className="w-5 h-5 animate-spin" />
                      Generating Roadmap...
                    </>
                  ) : (
                    <>
                      <Sparkles className="w-5 h-5 transition-transform group-hover:scale-110" />
                      Generate My Roadmap
                    </>
                  )}
                </Button>
              </form>
            </Form>
          </div>

          <AnimatePresence>
            {result && !generateRoadmap.isPending && (
              <motion.div
                initial={{ opacity: 0, y: 40 }}
                animate={{ opacity: 1, y: 0 }}
                exit={{ opacity: 0, y: -20 }}
                transition={{ duration: 0.5, ease: "easeOut" }}
                className="relative"
              >
                <div className="absolute right-0 -top-4 z-20 hidden md:flex gap-2">
                  {isSignedIn ? (
                    <Button onClick={handleShare} size="sm" variant="outline" className="shadow-sm font-bold gap-2" disabled={shareRoadmap.isPending || saveRoadmap.isPending} data-testid="button-share-sticky">
                      {shareRoadmap.isPending ? <Loader2 className="w-4 h-4 animate-spin" /> : <Share2 className="w-4 h-4" />}
                      Share
                    </Button>
                  ) : null}
                  {isSignedIn ? (
                    <Button onClick={handleSave} size="sm" className="shadow-sm font-bold gap-2" disabled={saveRoadmap.isPending} data-testid="button-save-sticky">
                      {saveRoadmap.isPending ? <Loader2 className="w-4 h-4 animate-spin" /> : <Save className="w-4 h-4" />}
                      Save
                    </Button>
                  ) : (
                    <Button onClick={() => setLocation("/sign-in")} size="sm" variant="outline" className="shadow-sm font-bold gap-2">
                      <LogIn className="w-4 h-4" /> Sign in to Save
                    </Button>
                  )}
                </div>
                
                <RoadmapDisplay roadmap={result} />

                <AdSenseBanner slot="below-roadmap" className="my-8" />

                <div className="mt-4 flex flex-col md:flex-row justify-center gap-4 pb-12">
                  {isSignedIn ? (
                    <Button onClick={handleShare} size="lg" variant="outline" className="w-full md:w-auto font-bold gap-2 px-8 h-14 text-lg" disabled={shareRoadmap.isPending || saveRoadmap.isPending} data-testid="button-share-bottom">
                      {shareRoadmap.isPending ? <Loader2 className="w-5 h-5 animate-spin" /> : <Share2 className="w-5 h-5" />}
                      Share
                    </Button>
                  ) : null}
                  {isSignedIn ? (
                    <Button onClick={handleSave} size="lg" className="w-full md:w-auto font-bold gap-2 px-12 h-14 text-lg" disabled={saveRoadmap.isPending} data-testid="button-save-bottom">
                      {saveRoadmap.isPending ? <Loader2 className="w-5 h-5 animate-spin" /> : <Save className="w-5 h-5" />}
                      Save to Profile
                    </Button>
                  ) : (
                    <Button onClick={() => setLocation("/sign-in")} size="lg" className="w-full md:w-auto font-bold gap-2 px-12 h-14 text-lg" data-testid="button-sign-in-to-save">
                      <LogIn className="w-5 h-5" /> Sign in to Save
                    </Button>
                  )}
                </div>
              </motion.div>
            )}
          </AnimatePresence>
        </div>

        {/* Sidebar layout on desktop */}
        {result && !generateRoadmap.isPending && (
          <div className="hidden lg:flex flex-col gap-6 sticky top-24 shrink-0 w-[300px]">

            <AdSenseBanner slot="sidebar-rectangle" size="rectangle" />
            <AdSenseBanner slot="sidebar-halfpage" size="halfpage" />

          </div>
        )}
      </div>

      <ExploreSkills />
    </div>
    </>
  );
}
